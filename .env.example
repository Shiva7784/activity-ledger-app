# ==========================================
# Frontend Configuration (Vite)
# ==========================================

# Firebase Web Client Credentials (Only needed if connecting to a real project)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Local Developer Settings
VITE_USE_EMULATOR=true
VITE_BACKEND_URL=http://localhost:3001

# ==========================================
# Backend Configuration (Express)
# ==========================================

PORT=3001
# Set this to connect Firebase Admin to the local Firestore Emulator
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# The Firebase Project ID to target (use any name if running on local emulator)
FIREBASE_PROJECT_ID=activity-ledger-app

# Service Account Key JSON (Required for production/real Firebase instance)
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
