{
  "name": "activity-ledger-root",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "client": "npm --prefix client run dev",
    "server": "npm --prefix server run dev",
    "emulators": "firebase emulators:start",
    "dev:all": "concurrently -n \"emulators,server,client\" -c \"cyan,magenta,green\" \"npm run emulators\" \"npm run server\" \"npm run client\"",
    "build:client": "npm --prefix client run build",
    "build:server": "npm --prefix server run build",
    "build:all": "npm run build:client && npm run build:server",
    "lint:client": "npm --prefix client run lint",
    "lint:server": "npm --prefix server run lint"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "firebase-tools": "^13.11.2"
  }
}
